{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/acronis/refs/heads/main/json-schema/account-management-token-response-schema.json",
  "title": "TokenResponse",
  "description": "OAuth2 token response",
  "type": "object",
  "properties": {
    "access_token": {
      "type": "string",
      "description": "JWT access token",
      "example": "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9..."
    },
    "token_type": {
      "type": "string",
      "enum": [
        "Bearer"
      ],
      "example": "Bearer"
    },
    "expires_in": {
      "type": "integer",
      "description": "Token lifetime in seconds",
      "example": 3600
    },
    "refresh_token": {
      "type": "string",
      "description": "Refresh token for obtaining new access tokens"
    },
    "scope": {
      "type": "string",
      "description": "Granted OAuth2 scopes"
    }
  }
}