{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/acronis/refs/heads/main/json-schema/account-management-usage-item-schema.json",
  "title": "UsageItem",
  "description": "Usage metric for a specific service or resource",
  "type": "object",
  "properties": {
    "offering_item": {
      "type": "string",
      "description": "Name of the offering item",
      "example": "vms"
    },
    "application_id": {
      "type": "string",
      "format": "uuid"
    },
    "value": {
      "type": "number",
      "description": "Current usage value",
      "example": 42
    },
    "edition": {
      "type": "string"
    }
  }
}